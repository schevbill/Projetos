<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SnakeGame" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_green_light</item>
        <item name="colorOnPrimary">@color/background_dark</item>
        <item name="colorSecondary">@color/accent_red</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <!-- Tema sem barra de status para a tela de jogo -->
    <style name="Theme.SnakeGame.Fullscreen" parent="Theme.SnakeGame">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Estilo dos botões principais -->
    <style name="Widget.SnakeGame.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_green</item>
        <item name="android:textColor">@color/background_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Estilo dos botões secundários -->
    <style name="Widget.SnakeGame.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_green</item>
        <item name="android:textColor">@color/primary_green</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Botões de direção (D-pad) -->
    <style name="Widget.SnakeGame.Button.Direction" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/button_direction</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

</resources>
