generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  cpfCnpj   String?
  phone     String?
  birthDate DateTime?
  address   String?
  password  String
  role      String   @default("CUSTOMER")
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  category    String?
  categoryId  String?
  categoryRel Category?   @relation(fields: [categoryId], references: [id])
  available   Boolean     @default(true)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Coupon {
  id         String    @id @default(cuid())
  code       String    @unique
  discount   Float
  type       String    @default("PERCENTAGE")
  maxUses    Int?
  uses       Int       @default(0)
  expiresAt  DateTime?
  active     Boolean   @default(true)
  orders     Order[]
  createdAt  DateTime  @default(now())
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  customerName    String
  customerPhone   String
  address         String
  items           OrderItem[]
  subtotal        Float
  discount        Float       @default(0)
  total           Float
  paymentMethod   String
  paymentStatus   String      @default("PENDING")
  status          String      @default("PENDING")
  notes           String?
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  user            User?       @relation(fields: [userId], references: [id])
  motoboyId       String?
  motoboy         Motoboy?    @relation(fields: [motoboyId], references: [id])
  printedLabel    Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Motoboy {
  id        String   @id @default(cuid())
  name      String
  phone     String
  vehicle   String?
  plate     String?
  active    Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
}

model Printer {
  id        String   @id @default(cuid())
  name      String
  ip        String?
  port      Int?     @default(9100)
  type      String   @default("THERMAL")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ConfigPix {
  id        String   @id @default("default")
  pixKey    String   @default("")
  pixName   String   @default("")
  pixCity   String   @default("")
  updatedAt DateTime @updatedAt
}
