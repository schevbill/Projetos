generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  cpfCnpj          String?
  phone            String?
  birthDate        DateTime?
  password         String
  role             String    @default("CUSTOMER")
  orders           Order[]
  addresses        Address[]
  sessionToken     String?
  sessionExpiresAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String   @default("Casa")
  cep         String?
  logradouro  String
  numero      String
  complemento String?
  bairro      String?
  cidade      String
  estado      String?
  createdAt   DateTime @default(now())
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  categoryId  String?
  categoryRel Category?   @relation(fields: [categoryId], references: [id])
  available   Boolean     @default(true)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Coupon {
  id         String    @id @default(cuid())
  code       String    @unique
  discount   Float
  type       String    @default("PERCENTAGE")
  maxUses    Int?
  uses       Int       @default(0)
  expiresAt  DateTime?
  active     Boolean   @default(true)
  orders     Order[]
  createdAt  DateTime  @default(now())
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  customerName    String
  customerPhone   String
  address         String
  items           OrderItem[]
  subtotal        Float
  discount        Float       @default(0)
  total           Float
  paymentMethod   String
  paymentStatus   String      @default("PENDING")
  status          String      @default("PENDING")
  notes           String?
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  user            User?       @relation(fields: [userId], references: [id])
  motoboyId       String?
  motoboy         Motoboy?    @relation(fields: [motoboyId], references: [id])
  printedLabel    Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model VehicleType {
  id        String           @id @default(cuid())
  name      String           @unique
  vehicles  MotoboyVehicle[]
  createdAt DateTime         @default(now())
}

model Motoboy {
  id          String           @id @default(cuid())
  name        String
  phone       String
  cpfCnpj     String?
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?
  vehicles    MotoboyVehicle[]
  active      Boolean          @default(true)
  orders      Order[]
  createdAt   DateTime         @default(now())
}

model MotoboyVehicle {
  id            String       @id @default(cuid())
  motoboyId     String
  motoboy       Motoboy      @relation(fields: [motoboyId], references: [id], onDelete: Cascade)
  vehicleTypeId String?
  vehicleType   VehicleType? @relation(fields: [vehicleTypeId], references: [id])
  plate         String?
  createdAt     DateTime     @default(now())
}

model Printer {
  id        String   @id @default(cuid())
  name      String
  ip        String?
  port      Int?     @default(9100)
  type      String   @default("THERMAL")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ConfigPix {
  id        String   @id @default("default")
  pixKey    String   @default("")
  pixName   String   @default("")
  pixCity   String   @default("")
  updatedAt DateTime @updatedAt
}

model ConfigEmail {
  id        String   @id @default("default")
  host      String   @default("smtp.gmail.com")
  port      Int      @default(587)
  user      String   @default("")
  pass      String   @default("")
  from      String   @default("")
  active    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model ConfigSystem {
  id                 String   @id @default("default")
  whatsappCustomer   Boolean  @default(true)
  whatsappMotoboy    Boolean  @default(true)
  logRetentionDays   Int      @default(30)
  updatedAt          DateTime @updatedAt
}

model Log {
  id          String   @id @default(cuid())
  action      String   // CREATE | UPDATE | DELETE | LOGIN
  entity      String   // USER | ORDER | PRODUCT | COUPON | ADDRESS | MOTOBOY | PRINTER | CONFIG
  entityId    String?
  description String
  userId      String?
  userName    String?
  userRole    String?
  ip          String?
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  @@index([entity])
  @@index([createdAt])
  @@index([userId])
}
